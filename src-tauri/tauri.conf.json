{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "D-Space（供应商管理）",
  "version": "1.0.1",
  "identifier": "com.digiwise.supplieradmin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3003",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:prod"
  },
  "app": {
    "macOSPrivateApi": false,
    "windows": [
      {
        "title": "D-Space（供应商管理）",
        "width": 1680,
        "height": 920,
        "minWidth": 1366,
        "minHeight": 860,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://bikewise.oss-cn-shenzhen.aliyuncs.com/d-space/supplier-desktop/{{target}}/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI1QzM2NEMzMjE4NUMwMjQKUldRa3dJVWh3MlREdFNMT3MveTlodnZYemd4N3JhUHoyaE11aWUwZnlVU3NmTEZuSVVYczVBRUYK"
    }
  }
}
